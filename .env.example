# ========================================
# OFINA Environment Variables
# Copy sang .env.local và điền giá trị thật
# ========================================

# Supabase (lấy từ supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...  # Chỉ dùng server-side

# Site
NEXT_PUBLIC_SITE_URL=https://ofina.vn
NEXT_PUBLIC_SITE_NAME=OFINA

# Contact
NEXT_PUBLIC_HOTLINE=0325669996
NEXT_PUBLIC_ZALO_URL=https://zalo.me/0325669996
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/ofina.vn
NEXT_PUBLIC_EMAIL=contact@ofina.vn

# Showroom (chi nhánh được khai báo cứng trong lib/utils.ts → BRANCHES)
NEXT_PUBLIC_ADDRESS=135 đường K2, Phường Phú Đô, Hà Nội
NEXT_PUBLIC_GOOGLE_MAPS_URL=https://maps.google.com/...

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# Notifications (Telegram bot nhận đơn hàng)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin
ADMIN_EMAILS=admin@ofina.vn
